{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orchestix.org/schema/ccs-schema-v0.1.1.json",
  "title": "CCS Blueprint v0.1.1",
  "description": "Cognitive Coordination Structure (CCS) blueprint fractal para ORCHESTIXX",
  "type": "object",
  "required": ["version", "id", "metadata", "tasks", "governance"],
  "properties": {
    "version": {
      "type": "string",
      "const": "0.1.1",
      "description": "Versión del estándar CCS"
    },
    "id": {
      "type": "string",
      "description": "Identificador único del blueprint (UUID o similar)"
    },
    "metadata": {
      "type": "object",
      "required": ["created_at", "created_by", "description"],
      "properties": {
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "created_by": {
          "type": "string",
          "description": "Origen de la orden (usuario, sistema, ACI)"
        },
        "description": {
          "type": "string",
          "description": "Descripción humana del propósito del blueprint"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "action", "inputs", "outputs"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Identificador único de la tarea dentro del blueprint"
          },
          "action": {
            "type": "string",
            "description": "Nombre de la capacidad A2A (p.ej. code_review, run_tests, deploy_service)"
          },
          "inputs": {
            "type": "object",
            "description": "Inputs requeridos por la acción",
            "additionalProperties": true
          },
          "outputs": {
            "type": "object",
            "description": "Outputs esperados de la acción",
            "additionalProperties": true
          },
          "params": {
            "type": "object",
            "description": "Parámetros de configuración de la tarea",
            "additionalProperties": true
          },
          "depends_on": {
            "type": "array",
            "description": "Lista de IDs de tareas de las que depende esta tarea",
            "items": { "type": "string" },
            "default": []
          },
          "metadata": {
            "type": "object",
            "description": "Metadata específica de la tarea",
            "additionalProperties": true
          }
        },
        "additionalProperties": false
      }
    },
    "governance": {
      "type": "object",
      "description": "Evaluación P1–P8 a nivel de blueprint",
      "required": [
        "cost_estimate",
        "time_estimate",
        "ethics_score",
        "risk_level",
        "quality_requirements",
        "compliance_requirements",
        "security_requirements",
        "org_alignment"
      ],
      "properties": {
        "cost_estimate": {
          "type": "number",
          "description": "P1 – Estimación de coste relativo o absoluto"
        },
        "time_estimate": {
          "type": "number",
          "description": "P2 – Estimación de tiempo (ms, s, o unidad acordada)"
        },
        "ethics_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "P3 – Score ético normalizado 0–1"
        },
        "risk_level": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"],
          "description": "P4 – Nivel de riesgo operativo"
        },
        "quality_requirements": {
          "type": "string",
          "description": "P5 – Requisitos de calidad aplicables"
        },
        "compliance_requirements": {
          "type": "string",
          "description": "P6 – Normativas / compliance relevantes"
        },
        "security_requirements": {
          "type": "string",
          "description": "P7 – Requisitos de seguridad"
        },
        "org_alignment": {
          "type": "string",
          "description": "P8 – Cómo se alinea con la estrategia organizacional"
        }
      },
      "additionalProperties": false
    },
    "sub_blueprints": {
      "type": "array",
      "description": "Blueprints fractales anidados que siguen el mismo schema CCS",
      "items": { "$ref": "#" },
      "default": []
    },
    "dag": {
      "type": "object",
      "description": "Representación explícita del grafo de dependencias",
      "required": ["nodes", "edges"],
      "properties": {
        "nodes": {
          "type": "array",
          "items": {
            "type": "string",
            "description": "IDs de tareas presentes en tasks"
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from", "to"],
            "properties": {
              "from": { "type": "string" },
              "to": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "integrity_hash": {
      "type": "string",
      "description": "Hash de integridad del blueprint completo (p.ej. SHA-256)"
    },
    "signature": {
      "type": "string",
      "description": "Firma del organismo ACI o entidad que aprueba la orden"
    }
  },
  "additionalProperties": false
}
